# Copia para .env e preenche. NUNCA commits o .env (token secreto).
#
# Token OAuth (formato oauth:...):
#   - https://twitchtokengenerator.com/  → "Custom Scope" → chat:read (e chat:edit se fores escrever no chat)
#   - ou https://twitchapps.com/tmi/ (token só para IRC / leitura de chat)
#
# TWITCH_BOT_USERNAME = login da conta que gerou o token (minúsculas, igual ao site da Twitch).
# TWITCH_CHANNEL      = canal onde a live corre (só o nome, sem #).

TWITCH_BOT_USERNAME=teu_login
TWITCH_CHANNEL=teu_canal
TWITCH_OAUTH_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WebSocket local para o jogo no browser conectar (só este PC)
TWITCH_BRIDGE_HOST=127.0.0.1
TWITCH_BRIDGE_PORT=8765

# GitHub Pages: usa Secrets TWITCH_OAUTH_TOKEN, TWITCH_BOT_USERNAME, TWITCH_CHANNEL
# (Settings → Secrets → Actions). O workflow gera twitch-config.js no deploy — ver README.
